<script>
    let fullData = null;
    let hourlyChart, monthlyChart, hourlyAvgChart, movingAvgChart = null;
    let map = null;
    let geojsonLayer = null;

    // ---------- 手动解析 CSV，处理末尾逗号 ----------
    function parseCSV(csvText) {
        const lines = csvText.trim().split(/\r?\n/);
        if (lines.length === 0) return [];
        let headers = lines[0].split(',').map(h => h.trim());
        while (headers.length > 0 && headers[headers.length-1] === "") {
            headers.pop();
        }
        const rows = [];
        for (let i = 1; i < lines.length; i++) {
            const line = lines[i];
            if (!line.trim()) continue;
            let values = line.split(',').map(v => v.trim());
            while (values.length > headers.length && values[values.length-1] === "") {
                values.pop();
            }
            if (values.length > headers.length) values = values.slice(0, headers.length);
            while (values.length < headers.length) values.push("");
            const row = {};
            for (let j = 0; j < headers.length; j++) {
                row[headers[j]] = values[j];
            }
            rows.push(row);
        }
        return rows;
    }

    // ---------- 专门解析 "DD/MM/YY HH:MM" 格式日期 ----------
    function parseDateFromString(dateStr) {
        if (!dateStr) return null;
        const match = dateStr.match(/^(\d{1,2})\/(\d{1,2})\/(\d{2})\s+(\d{1,2}):(\d{2})$/);
        if (!match) return null;
        const day = parseInt(match[1], 10);
        const month = parseInt(match[2], 10);
        const yearShort = parseInt(match[3], 10);
        const hour = parseInt(match[4], 10);
        const minute = parseInt(match[5], 10);
        const year = 2000 + yearShort;
        const isoStr = `${year}-${String(month).padStart(2,'0')}-${String(day).padStart(2,'0')}T${String(hour).padStart(2,'0')}:${String(minute).padStart(2,'0')}:00.000Z`;
        return { year, month, day, hour, minute, isoStr };
    }

    // ---------- 转换 rows 到 fullData ----------
    function transformCsvToData(rows) {
        const data = [];
        const countriesSet = new Set();
        const yearsSet = new Set();

        for (const row of rows) {
            const dtStr = row.Date || row.datetime;
            if (!dtStr) continue;
            const parsed = parseDateFromString(dtStr);
            if (!parsed) continue;
            const year = parsed.year;
            const month = parsed.month;
            const hour = parsed.hour;
            yearsSet.add(year);

            const values = {};
            for (const [key, val] of Object.entries(row)) {
                if (key === 'Date' || key === 'datetime') continue;
                const num = parseFloat(val);
                if (!isNaN(num)) {
                    values[key] = num;
                    countriesSet.add(key);
                }
            }
            data.push({
                datetime: parsed.isoStr,
                year: year,
                month: month,
                hour: hour,
                values: values
            });
        }
        const countries = Array.from(countriesSet).sort();
        const years = Array.from(yearsSet).sort();
        return { countries, years, data };
    }

    // ---------- 加载 CSV ----------
    async function fetchData() {
        try {
            const response = await fetch('load.csv');
            if (!response.ok) throw new Error(`HTTP ${response.status}`);
            const csvText = await response.text();
            const rows = parseCSV(csvText);
            if (rows.length === 0) throw new Error('CSV 解析后无数据行');
            fullData = transformCsvToData(rows);
            console.log(`负荷数据加载成功, 数据点: ${fullData.data.length}, 国家: ${fullData.countries.length}`);
            return true;
        } catch (err) {
            alert(`数据加载失败: ${err.message}\n请确保 load.csv 文件存在且格式正确。`);
            console.error(err);
            return false;
        }
    }

    // ---------- 界面控件 ----------
    function buildCountryCheckboxes() {
        const container = document.getElementById('countryCheckboxes');
        container.innerHTML = '';
        fullData.countries.forEach(country => {
            const label = document.createElement('label');
            const cb = document.createElement('input');
            cb.type = 'checkbox';
            cb.value = country;
            cb.checked = true;
            cb.addEventListener('change', () => refresh());
            label.appendChild(cb);
            label.appendChild(document.createTextNode(country));
            container.appendChild(label);
        });
        document.getElementById('selectAllBtn').disabled = false;
        document.getElementById('clearAllBtn').disabled = false;
    }

    function getSelectedCountries() {
        const checkboxes = document.querySelectorAll('#countryCheckboxes input[type="checkbox"]');
        const selected = [];
        checkboxes.forEach(cb => { if (cb.checked) selected.push(cb.value); });
        return selected;
    }

    function selectAll() {
        document.querySelectorAll('#countryCheckboxes input[type="checkbox"]').forEach(cb => cb.checked = true);
        refresh();
    }
    function clearAll() {
        document.querySelectorAll('#countryCheckboxes input[type="checkbox"]').forEach(cb => cb.checked = false);
        refresh();
    }

    function getDateTimeFromParts(dateStr, hour) {
        if (!dateStr || hour === undefined) return null;
        const d = new Date(dateStr);
        d.setHours(parseInt(hour), 0, 0, 0);
        return d;
    }

    function formatDateTime(date) {
        const year = date.getFullYear();
        const month = String(date.getMonth() + 1).padStart(2, '0');
        const day = String(date.getDate()).padStart(2, '0');
        const hour = String(date.getHours()).padStart(2, '0');
        return `${year}/${month}/${day} ${hour}:00`;
    }

    function initControls() {
        const yearSelect = document.getElementById('yearSelect');
        const monthSelect = document.getElementById('monthSelect');
        yearSelect.innerHTML = '<option value="">-- Select year --</option>' +
            fullData.years.map(y => `<option value="${y}">${y}</option>`).join('');
        yearSelect.disabled = false;
        monthSelect.disabled = false;
        document.getElementById('refreshBtn').disabled = false;
        if (fullData.years.length) yearSelect.value = fullData.years[0];
        monthSelect.value = "1";
        const year = parseInt(yearSelect.value);
        if (year) {
            document.getElementById('startDate').value = `${year}-01-01`;
            document.getElementById('endDate').value = `${year}-12-31`;
            document.getElementById('startHour').value = "0";
            document.getElementById('endHour').value = "23";
        }
        document.getElementById('startDate').disabled = false;
        document.getElementById('endDate').disabled = false;
        document.getElementById('startHour').disabled = false;
        document.getElementById('endHour').disabled = false;
    }

    // -------------------- 绘图函数 --------------------
    function drawHourly(year, countries, startDateTime, endDateTime) {
        if (!hourlyChart || !countries.length) return;
        let dataPoints = fullData.data.filter(d => d.year === year);
        if (startDateTime && endDateTime) {
            const start = new Date(startDateTime);
            const end = new Date(endDateTime);
            dataPoints = dataPoints.filter(d => new Date(d.datetime) >= start && new Date(d.datetime) <= end);
        }
        if (dataPoints.length === 0) { hourlyChart.setOption({ series: [] }, true); return; }
        dataPoints.sort((a,b) => new Date(a.datetime) - new Date(b.datetime));
        const xData = dataPoints.map(d => formatDateTime(new Date(d.datetime)));
        const series = [];
        for (let country of countries) {
            const yData = dataPoints.map(d => d.values[country] !== undefined ? d.values[country] : null);
            series.push({ name: country, type: 'line', data: yData, connectNulls: false, lineStyle: { width: 1.5 }, showSymbol: false });
        }
        hourlyChart.setOption({
            tooltip: { trigger: 'axis', valueFormatter: v => v !== null ? v.toFixed(2) + ' MW' : 'N/A' },
            xAxis: { type: 'category', data: xData, axisLabel: { rotate: 45, interval: 'auto' } },
            yAxis: { type: 'value', name: 'MW' },
            series: series,
            dataZoom: [{ type: 'inside', start: 0, end: 100 }, { type: 'slider', start: 0, end: 100 }]
        }, true);
    }

    function drawMonthly(year, countries) {
        if (!monthlyChart || !countries.length) return;
        const monthlyAvg = {};
        for (let c of countries) monthlyAvg[c] = Array(12).fill(null);
        const monthlyCount = Array(12).fill(0);
        fullData.data.forEach(d => {
            if (d.year !== year) return;
            const m = d.month - 1;
            for (let c of countries) {
                const val = d.values[c];
                if (val !== null && val !== undefined) {
                    if (monthlyAvg[c][m] === null) monthlyAvg[c][m] = 0;
                    monthlyAvg[c][m] += val;
                    monthlyCount[m] = (monthlyCount[m] || 0) + 1;
                }
            }
        });
        const series = [];
        const months = ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec'];
        for (let c of countries) {
            const yData = monthlyAvg[c].map((sum, idx) => {
                if (sum !== null && monthlyCount[idx] > 0) return sum / monthlyCount[idx];
                return null;
            });
            series.push({ name: c, type: 'line', data: yData, connectNulls: false, lineStyle: { width: 2 }, symbol: 'circle', symbolSize: 6 });
        }
        monthlyChart.setOption({
            tooltip: { trigger: 'axis', valueFormatter: v => v !== null ? v.toFixed(2) + ' MW' : 'N/A' },
            xAxis: { type: 'category', data: months },
            yAxis: { type: 'value', name: 'MW' },
            series: series
        }, true);
    }

    function drawHourlyAvg(year, month, selectedCountries) {
        if (!hourlyAvgChart || !year || !month) return;
        if (!selectedCountries.length) return;
        const hourlyData = {};
        for (let c of selectedCountries) {
            hourlyData[c] = Array(24).fill(null);
            hourlyData[`${c}_count`] = Array(24).fill(0);
        }
        fullData.data.forEach(d => {
            if (d.year === year && d.month === month) {
                const h = d.hour;
                for (let c of selectedCountries) {
                    const val = d.values[c];
                    if (val !== null && val !== undefined) {
                        if (hourlyData[c][h] === null) hourlyData[c][h] = 0;
                        hourlyData[c][h] += val;
                        hourlyData[`${c}_count`][h]++;
                    }
                }
            }
        });
        const series = [];
        const hours = Array.from({length: 24}, (_,i) => `${i}:00`);
        for (let c of selectedCountries) {
            const yData = hourlyData[c].map((sum, idx) => {
                if (sum !== null && hourlyData[`${c}_count`][idx] > 0) return sum / hourlyData[`${c}_count`][idx];
                return null;
            });
            series.push({ name: c, type: 'line', data: yData, connectNulls: false, lineStyle: { width: 2 }, symbol: 'circle', symbolSize: 6 });
        }
        hourlyAvgChart.setOption({
            tooltip: { trigger: 'axis', valueFormatter: v => v !== null ? v.toFixed(2) + ' MW' : 'N/A' },
            xAxis: { type: 'category', data: hours },
            yAxis: { type: 'value', name: 'MW' },
            series: series
        }, true);
    }

    // ---------- 7日滑动平均对比图 (2025 vs 2026) ----------
    function drawMovingAvg(selectedCountries) {
        if (!movingAvgChart) return;
        if (!selectedCountries.length) {
            movingAvgChart.setOption({ series: [] }, true);
            return;
        }

        // 提取2025和2026年数据
        const data2025 = [];
        const data2026 = [];
        fullData.data.forEach(d => {
            if (d.year === 2025 && d.values) data2025.push(d);
            if (d.year === 2026 && d.values) data2026.push(d);
        });

        if (data2025.length === 0 && data2026.length === 0) {
            movingAvgChart.setOption({
                title: { show: true, text: '无2025或2026年数据', left: 'center', top: 'center' }
            }, true);
            return;
        }

        // 辅助函数：计算每日平均负荷（基于所选国家平均）
        function computeDailyAvg(dataArray, countries) {
            const dailyMap = new Map(); // key: "YYYY-MM-DD", value: { sum, count }
            dataArray.forEach(record => {
                const dateObj = new Date(record.datetime);
                const dateKey = `${dateObj.getFullYear()}-${String(dateObj.getMonth()+1).padStart(2,'0')}-${String(dateObj.getDate()).padStart(2,'0')}`;
                let daily = dailyMap.get(dateKey);
                if (!daily) {
                    daily = { sum: 0, count: 0 };
                    dailyMap.set(dateKey, daily);
                }
                // 计算所有选中国家的平均负荷（如果某个国家无数据则跳过）
                let countrySum = 0;
                let countryCnt = 0;
                for (let c of countries) {
                    const val = record.values[c];
                    if (val !== null && val !== undefined && !isNaN(val)) {
                        countrySum += val;
                        countryCnt++;
                    }
                }
                if (countryCnt > 0) {
                    const avg = countrySum / countryCnt;
                    daily.sum += avg;
                    daily.count++;
                }
            });
            // 转为数组并按日期排序
            const dailyAvgs = [];
            for (let [dateKey, val] of dailyMap.entries()) {
                if (val.count > 0) {
                    dailyAvgs.push({ date: dateKey, avg: val.sum / val.count });
                }
            }
            dailyAvgs.sort((a,b) => a.date.localeCompare(b.date));
            return dailyAvgs;
        }

        const daily2025 = computeDailyAvg(data2025, selectedCountries);
        const daily2026 = computeDailyAvg(data2026, selectedCountries);

        // 计算7日滑动平均
        function movingAverage(dailyArray, windowSize = 7) {
            const result = [];
            const n = dailyArray.length;
            for (let i = 0; i < n; i++) {
                let sum = 0;
                let count = 0;
                for (let j = Math.max(0, i - Math.floor(windowSize/2)); j <= Math.min(n-1, i + Math.floor(windowSize/2)); j++) {
                    sum += dailyArray[j].avg;
                    count++;
                }
                result.push(count > 0 ? sum / count : null);
            }
            return result;
        }

        const ma2025 = movingAverage(daily2025);
        const ma2026 = movingAverage(daily2026);

        // 准备x轴（天数序号，从1开始）
        const xAxis2025 = daily2025.map((_, idx) => idx + 1);
        const xAxis2026 = daily2026.map((_, idx) => idx + 1);

        movingAvgChart.setOption({
            tooltip: { trigger: 'axis', valueFormatter: v => v !== null ? v.toFixed(2) + ' MW' : 'N/A' },
            xAxis: { type: 'value', name: 'Day of Year', min: 1, max: 366 },
            yAxis: { type: 'value', name: 'MW' },
            series: [
                {
                    name: '2025 (7-day MA)',
                    type: 'line',
                    data: ma2025,
                    xAxisIndex: 0,
                    smooth: false,
                    lineStyle: { color: '#000000', width: 2 },
                    symbol: 'none'
                },
                {
                    name: '2026 (7-day MA)',
                    type: 'line',
                    data: ma2026,
                    xAxisIndex: 0,
                    smooth: false,
                    lineStyle: { color: '#cc0000', width: 2 },
                    symbol: 'none'
                }
            ],
            dataZoom: [{ type: 'inside', start: 0, end: 100 }, { type: 'slider', start: 0, end: 100 }]
        }, true);
    }

    // ---------- 地图部分 (与电价相同，仅单位改为MW) ----------
    const countryNameToCode = {
        "Germany": "DE", "France": "FR", "Italy": "IT", "Spain": "ES",
        "Greece": "GR", "Romania": "RO", "Hungary": "HU", "Austria": "AT",
        "Poland": "PL", "Slovakia": "SK", "Serbia": "RS", "Croatia": "HR",
        "Bulgaria": "BG", "Netherlands": "NL", "Belgium": "BE", "Czech Republic": "CZ",
        "Denmark": "DK", "Finland": "FI", "Ireland": "IE", "Lithuania": "LT",
        "Luxembourg": "LU", "Norway": "NO", "Portugal": "PT", "Slovenia": "SI",
        "Sweden": "SE", "Switzerland": "CH", "United Kingdom": "GB"
    };
    
    function getColorForLoad(load, minLoad, maxLoad) {
        if (load === null || load === undefined || isNaN(load)) return "#b0b0b0";
        if (minLoad === maxLoad) return "#e67e22";
        let t = (load - minLoad) / (maxLoad - minLoad);
        t = Math.min(1, Math.max(0, t));
        const startR = 255, startG = 204, startB = 204;
        const endR = 204, endG = 0, endB = 0;
        const r = Math.round(startR + t * (endR - startR));
        const g = Math.round(startG + t * (endG - startG));
        const b = Math.round(startB + t * (endB - startB));
        return `rgb(${r}, ${g}, ${b})`;
    }
    
    function getCountryCodeFromFeature(feature) {
        let code = feature.properties?.ISO_A2 || feature.properties?.iso_a2;
        if (code && code.length === 2) return code;
        const name = feature.properties?.ADMIN || feature.properties?.name;
        if (name && countryNameToCode[name]) return countryNameToCode[name];
        return null;
    }
    
    function updateLegend(minLoad, maxLoad) {
        let legendDiv = document.querySelector('.map-legend');
        const mapContainer = document.getElementById('europeMap').parentNode;
        if (!legendDiv) {
            legendDiv = document.createElement('div');
            legendDiv.className = 'map-legend';
            mapContainer.style.position = 'relative';
            mapContainer.appendChild(legendDiv);
        }
        if (minLoad === null || maxLoad === null || minLoad === maxLoad) {
            legendDiv.innerHTML = `<h4>Monthly Avg Load (MW)</h4><div class="gradient-bar"></div><div class="labels"><span>N/A</span><span>N/A</span></div>`;
        } else {
            legendDiv.innerHTML = `<h4>Monthly Avg Load (MW)</h4><div class="gradient-bar"></div><div class="labels"><span>${minLoad.toFixed(1)} MW</span><span>${maxLoad.toFixed(1)} MW</span></div>`;
        }
    }
    
    async function drawMap(year, month) {
        if (!map) return;
        if (geojsonLayer) map.removeLayer(geojsonLayer);
        
        const avgMap = {};
        for (let c of fullData.countries) {
            avgMap[c] = { sum: 0, count: 0 };
        }
        fullData.data.forEach(d => {
            if (d.year === year && d.month === month) {
                for (let c of fullData.countries) {
                    const val = d.values[c];
                    if (val !== null && val !== undefined && !isNaN(val)) {
                        avgMap[c].sum += val;
                        avgMap[c].count++;
                    }
                }
            }
        });
        const countryLoads = {};
        const loadValues = [];
        for (let c of fullData.countries) {
            const avg = avgMap[c].count > 0 ? avgMap[c].sum / avgMap[c].count : null;
            countryLoads[c] = avg;
            if (avg !== null) loadValues.push(avg);
        }
        const minLoad = loadValues.length ? Math.min(...loadValues) : null;
        const maxLoad = loadValues.length ? Math.max(...loadValues) : null;
        updateLegend(minLoad, maxLoad);
        
        const geojsonUrl = 'https://raw.githubusercontent.com/datasets/geo-countries/master/data/countries.geojson';
        try {
            const response = await fetch(geojsonUrl);
            const geoData = await response.json();
            
            geojsonLayer = L.geoJSON(geoData, {
                style: (feature) => {
                    const code = getCountryCodeFromFeature(feature);
                    let load = null;
                    if (code && countryLoads[code] !== undefined) load = countryLoads[code];
                    const fillColor = getColorForLoad(load, minLoad, maxLoad);
                    return {
                        color: '#2c3e50',
                        weight: 1.2,
                        fillColor: fillColor,
                        fillOpacity: 0.75,
                        opacity: 0.9
                    };
                },
                onEachFeature: (feature, layer) => {
                    const code = getCountryCodeFromFeature(feature);
                    let loadDisplay = 'N/A';
                    if (code && countryLoads[code] !== undefined && countryLoads[code] !== null) {
                        loadDisplay = countryLoads[code].toFixed(2) + ' MW';
                    } else {
                        loadDisplay = 'Data N/A';
                    }
                    const displayCode = code ? code : '?';
                    layer.bindTooltip(`${displayCode}: ${loadDisplay}`, { sticky: true });
                }
            }).addTo(map);
        } catch (err) {
            console.warn('GeoJSON 加载失败', err);
        }
    }

    // ---------- 全局刷新 ----------
    function refresh() {
        const year = parseInt(document.getElementById('yearSelect').value);
        const selectedCountries = getSelectedCountries();
        const startDateStr = document.getElementById('startDate').value;
        const startHour = document.getElementById('startHour').value;
        const endDateStr = document.getElementById('endDate').value;
        const endHour = document.getElementById('endHour').value;
        const startDateTime = startDateStr && startHour !== undefined ? getDateTimeFromParts(startDateStr, startHour) : null;
        const endDateTime = endDateStr && endHour !== undefined ? getDateTimeFromParts(endDateStr, endHour) : null;
        const month = parseInt(document.getElementById('monthSelect').value);
        if (!year) return;
        
        drawHourly(year, selectedCountries, startDateTime, endDateTime);
        drawMonthly(year, selectedCountries);
        drawHourlyAvg(year, month, selectedCountries);
        drawMap(year, month);
        drawMovingAvg(selectedCountries);   // 新增滑动平均图
    }
    
    function onYearChange() {
        const year = parseInt(document.getElementById('yearSelect').value);
        if (year) {
            document.getElementById('startDate').value = `${year}-01-01`;
            document.getElementById('endDate').value = `${year}-12-31`;
            document.getElementById('startHour').value = "0";
            document.getElementById('endHour').value = "23";
        }
        refresh();
    }
    
    // ---------- 初始化 ----------
    async function init() {
        const ok = await fetchData();
        if (!ok) return;
        document.getElementById('loadingMsg').style.display = 'none';
        document.getElementById('chartGrid').style.display = 'grid';
        
        hourlyChart = echarts.init(document.getElementById('hourlyChart'));
        monthlyChart = echarts.init(document.getElementById('monthlyChart'));
        hourlyAvgChart = echarts.init(document.getElementById('hourlyAvgChart'));
        movingAvgChart = echarts.init(document.getElementById('movingAvgChart'));
        
        // 初始化地图，固定欧洲视角
        map = L.map('europeMap').setView([50, 10], 4);
        L.tileLayer('https://{s}.basemaps.cartocdn.com/light_all/{z}/{x}/{y}{r}.png', {
            attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OSM</a> & CartoDB'
        }).addTo(map);
        
        window.addEventListener('resize', () => {
            hourlyChart.resize(); monthlyChart.resize(); hourlyAvgChart.resize(); movingAvgChart.resize();
            if (map) map.invalidateSize();
        });
        
        buildCountryCheckboxes();
        initControls();
        refresh();
        
        document.getElementById('selectAllBtn').addEventListener('click', selectAll);
        document.getElementById('clearAllBtn').addEventListener('click', clearAll);
        document.getElementById('yearSelect').addEventListener('change', onYearChange);
        document.getElementById('monthSelect').addEventListener('change', refresh);
        document.getElementById('refreshBtn').addEventListener('click', refresh);
        document.getElementById('startDate').addEventListener('change', refresh);
        document.getElementById('endDate').addEventListener('change', refresh);
        document.getElementById('startHour').addEventListener('change', refresh);
        document.getElementById('endHour').addEventListener('change', refresh);
    }
    
    init();
</script>
