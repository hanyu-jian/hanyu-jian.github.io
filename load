    <div id="loadingMsg" class="loading">Loading data...</div>
    <div class="chart-grid" style="display: none;" id="chartGrid">
        <div class="chart-card">
            <h3>Hourly Load Trends (multiple countries)</h3>
            <div id="hourlyChart" class="chart-container"></div>
        </div>
        <div class="chart-card">
            <h3>Monthly Average Load (multiple countries)</h3>
            <div id="monthlyChart" class="chart-container"></div>
        </div>
        <div class="chart-card full-width-card">
            <h3>Hourly Average Load (selected month) & European Map</h3>
            <div class="dual-panel">
                <div>
                    <div class="card-control">
                        <label>📆 Month for left chart:</label>
                        <select id="monthSelect" disabled>
                            <option value="">-- Select month --</option>
                            <option value="1">January</option><option value="2">February</option><option value="3">March</option>
                            <option value="4">April</option><option value="5">May</option><option value="6">June</option>
